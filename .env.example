# Copy to .env and fill in. All keys are consumed by the Python bot service only;
# the browser never receives them.

# Speech-to-text
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# LLM
GROQ_API_KEY=
# 70b-versatile is still fast on Groq and far more reliable at tool calling than
# 8b-instant; we run it for both speech and tools rather than splitting models.
# Worth A/B-ing: openai/gpt-oss-20b benchmarks faster than 8b on Groq with much
# better tool use; openai/gpt-oss-120b is the higher-intelligence fallback.
GROQ_MODEL=llama-3.3-70b-versatile
# Lower temperature => more deterministic tool calling (model emits send_email
# instead of just claiming it sent the mail).
GROQ_TEMPERATURE=0.4
# Ceiling on reply length so a stray long turn can't blow up time-to-finish.
# Replies are already one short sentence; this is a cap, not a target.
GROQ_MAX_TOKENS=160
LLM_PROVIDER=groq

# Text-to-speech
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# Transport (Daily WebRTC)
DAILY_API_KEY=

# Email (Resend) — powers the send_email voice tool.
RESEND_API_KEY=
# Sender address. Must be on a domain you've verified in Resend; the shared
# onboarding@resend.dev sandbox sender only delivers to your own account email.
EMAIL_FROM=onboarding@resend.dev
