# Copy to .env and fill in. All keys are consumed by the Python bot service only;
# the browser never receives them.

# Speech-to-text
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# LLM
GROQ_API_KEY=
# gpt-oss-20b: fast (faster than 8b on Groq), good tool use, and the most free-tier
# headroom. We DROPPED llama-3.3-70b-versatile — its 100K tokens/day free cap is the
# lowest on Groq, and a voice agent re-sends the whole context every turn, so it gets
# exhausted in a few dozen turns (the rate-limit errors we kept hitting).
# Fallback if 20b fumbles tools: openai/gpt-oss-120b (200K TPD, smarter, lower burst).
# The real fix once budget allows is Groq's paid Developer tier (10x limits) — then
# any model works and this stays a one-line swap.
GROQ_MODEL=openai/gpt-oss-20b
# Lower temperature => more deterministic tool calling (model emits send_email
# instead of just claiming it sent the mail).
GROQ_TEMPERATURE=0.4
# Per-style reply-length ceilings (a cap, not a target — the persona's "earn the
# length" rule sets the real length; the cap just prevents mid-sentence truncation).
# Higher caps spend more of the free-tier daily token budget. Story leads the
# conversation, so it gets more room than the everyday companion.
GROQ_MAX_TOKENS_COMPANION=320
GROQ_MAX_TOKENS_STORY=512
LLM_PROVIDER=groq

# Context summarization — the durable free-tier fix for daily-token burn. Once the
# running context crosses a token/message threshold, older turns are compressed into
# a short summary (via the same Groq model) and recent turns are kept verbatim, so
# per-turn input stops growing without bound. Short sessions never trigger it.
SUMMARIZE_AT_TOKENS=4000
SUMMARIZE_AT_MESSAGES=24
SUMMARY_TARGET_TOKENS=1500
SUMMARY_KEEP_MESSAGES=6

# Conversation style / turn-taking. The web UI picks a style per session (?style=:
# companion or story); these tune each one. VAD stop_secs = how long a pause ends
# the user's turn — story waits a touch longer so short answers aren't barged over.
# STORY_IDLE_SECS > 0 lets Vivid re-engage when you go quiet (off by default; every
# idle nudge is a full LLM turn, so it's the most token-expensive option here — ~8
# is a reasonable trial). Per-style overrides: VAD_STOP_SECS_COMPANION / _STORY.
VAD_STOP_SECS_COMPANION=0.5
VAD_STOP_SECS_STORY=0.8
VAD_START_SECS=0.2
STORY_IDLE_SECS=0

# Text-to-speech
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121
# Emotion at the TTS layer (Cartesia Sonic-3 reads these as guidance). Leave
# CARTESIA_EMOTION UNSET (commented) to use the per-style defaults — companion
# sounds "content", story "excited". Set it to force one emotion across all styles,
# or set it to an explicit empty value to turn TTS emotion OFF and restore the plain
# original voice. Emotion only registers on a Sonic-3 model (CARTESIA_MODEL; code
# already defaults to sonic-3 — the library default sonic-3.5 may ignore it).
# Optional CARTESIA_SPEED (0.6–1.5). Best with a recommended voice:
# Leo/Jace/Kyle/Gavin/Maya/Tessa/Dana/Marian — the current voice still works.
#CARTESIA_EMOTION=excited
#CARTESIA_MODEL=sonic-3
#CARTESIA_SPEED=1.0

# ElevenLabs — streaming TTS (low latency). Powers the "English (ElevenLabs)"
# mode; voice is normally picked in the web UI. NOTE: the FREE tier can only use
# "premade" voices via the API — library/cloned voices (incl. the only Nigerian
# voice, "Fortunate") return 402 and play NO audio until you're on a paid plan.
# So this default is a premade voice; a Nigerian accent here needs a paid plan.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9
ELEVENLABS_MODEL=eleven_flash_v2_5
# Expressivity (more emotional delivery). These are the code defaults, shown so
# they're tunable; set any to an empty value to drop that knob. Lower stability =
# more emotional range but can loosen a cloned/Nigerian accent — raise it back
# toward 1.0 if the voice drifts. style/stability are 0.0–1.0.
ELEVENLABS_STYLE=0.45
ELEVENLABS_STABILITY=0.35
ELEVENLABS_SPEAKER_BOOST=true

# Spitch (https://spitch.app) — African-language STT/TTS that powers the
# Yoruba/Igbo voice modes (Deepgram/Cartesia don't support these). Only needed
# if you pick those languages in the web UI; English/Spanish ignore this.
SPITCH_API_KEY=
# Per-language voice IDs (verified valid against the Spitch API 2026-06-17).
# English (Nigerian) voices incl. john/lucy/henry/jude/kani; Hausa amina/aliyu/
# hasan/zainab; Igbo obinna/ngozi/amara/ebuka; Amharic hana/haile/tena.
SPITCH_ENGLISH_VOICE=lucy
SPITCH_YORUBA_VOICE=sade
SPITCH_IGBO_VOICE=obinna

# Transport (Daily WebRTC)
DAILY_API_KEY=

# Email (Resend) — powers the send_email voice tool.
RESEND_API_KEY=
# Sender address. Must be on a domain you've verified in Resend; the shared
# onboarding@resend.dev sandbox sender only delivers to your own account email.
EMAIL_FROM=onboarding@resend.dev

# Vision — the camera "look" tool. The voice LLM calls `look`; the browser captures
# one downscaled camera frame and this model (on OpenRouter) describes it in ~2
# sentences, which is fed back into the conversation. It's a SEPARATE provider on
# purpose: image tokens are billed on OpenRouter's quota and never compete with the
# Groq free-tier daily budget that keeps the voice loop alive. Swap VISION_MODEL for
# any OpenRouter vision model (e.g. openai/gpt-4o-mini, meta-llama/llama-4-scout).
OPEN_ROUTER_KEY=
VISION_MODEL=google/gemini-2.5-flash
# Keep the description short — it enters the Groq context as the tool result, so this
# is the only Groq-side token cost of vision.
VISION_MAX_TOKENS=120
# Timeouts (seconds): VISION = the OpenRouter call; FRAME = waiting for the browser to
# return a camera frame.
VISION_TIMEOUT_SECS=20
FRAME_TIMEOUT_SECS=15
