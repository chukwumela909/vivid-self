# Copy to .env and fill in. All keys are consumed by the Python bot service only;
# the browser never receives them.

# Speech-to-text
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
LLM_PROVIDER=groq
# Phase 4 dual-model routing target — architected, not wired in v1:
# GROQ_TOOL_MODEL=llama-3.3-70b-versatile

# Text-to-speech
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# Transport (Daily WebRTC)
DAILY_API_KEY=
